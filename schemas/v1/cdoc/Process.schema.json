{
  "$schema": "http://json-schema.org/2020-12/schema#",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/cdoc/Process.schema.json",
  "type": "object",
  "properties": {
    "businessKey": {
      "type": "string"
    },
    "dataSource": {
      "$ref": "DataSource.schema.json"
    },
    "version": {
      "type": "integer"
    },
    "edifactVersion": {
      "type": "integer"
    },
    "data": {
      "$ref": "ProcessData.schema.json"
    },
    "tenantId": {
      "type": "string",
      "default": "NONE"
    },
    "processDate": {
      "type": "string",
      "format": "date-time"
    }
  }
}