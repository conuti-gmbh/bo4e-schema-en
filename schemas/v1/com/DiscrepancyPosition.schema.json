{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema/master/schemas/v1/com/Abweichungsposition.schema.json",
  "title": "DiscrepancyPosition",
  "type": "object",
  "properties": {
    "discrepancyReasonCode": {
      "type": "string",
      "description": "Code des Abweichungsgrundes"
    },
    "discrepancyReasonCodeList": {
      "type": "string",
      "description": "Codeliste des Abweichungsgrund"
    },
    "discrepancyReasonNote": {
      "type": "string",
      "description": "Abweichungsgrund Bemerkung"
    },
    "associatedInvoice": {
      "type": "string",
      "description": "Angabe der Rechnungsnummer, auf die sich diese Abweichung bezieht"
    },
    "associatedOrder": {
      "type": "string",
      "description": "Angabe der Bestellungsnummer, auf die sich diese Abweichung bezieht"
    }
  }
}