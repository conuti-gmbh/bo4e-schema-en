{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/com/InvoicePosition.schema.json",
  "title": "InvoicePosition",
  "type": "object",
  "properties": {
    "individualPrice": {
      "$ref": "../com/Price.schema.json"
    },
    "deliveryUntil": {
      "type": "string",
      "format": "date-time"
    },
    "deliveryFrom": {
      "type": "string",
      "format": "date-time"
    },
    "positionQuantity": {
      "$ref": "../com/Quantity.schema.json"
    },
    "positionNumber": {
      "type": "integer",
      "faker": {
        "number.int": {
          "min": 1,
          "max": 10
        }
      }
    },
    "articleNumber": {
      "type": "string",
      "faker": {
        "string.numeric": 10
      }
    },
    "subtotalNet": {
      "$ref": "../com/Amount.schema.json"
    },
    "subtotalTax": {
      "$ref": "../com/TaxAmount.schema.json"
    },
    "timeRelatedQuantity": {
      "$ref": "../com/Quantity.schema.json"
    },
    "installment": {
      "$ref": "../com/Installment.schema.json"
    },
    "surcharge": {
      "$ref": "../com/Surcharge.schema.json"
    },
    "municipalDiscount": {
      "$ref": "../com/MunicipalDiscount.schema.json"
    },
    "totalSurchargeDiscountAmount": {
      "type": "number",
      "format": "float",
      "faker": {
        "number.float": {
          "multipleOf": 0.25,
          "min": 10,
          "max": 20
        }
      }
    },
    "correctionFactor": {
      "type": "number",
      "format": "float",
      "faker": {
        "number.float": {
          "multipleOf": 0.25,
          "min": 10,
          "max": 20
        }
      }
    },
    "executionDate": {
      "type": "string",
      "format": "date-time"
    }
  }
}