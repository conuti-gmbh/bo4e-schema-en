{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/com/Address.schema.json",
  "title": "Address",
  "type": "object",
  "properties": {
    "postalCode": {
      "type": "string",
      "faker": "location.zipCode"
    },
    "city": {
      "type": "string",
      "faker": "location.city"
    },
    "street": {
      "type": "string",
      "faker": "location.street"
    },
    "houseNumber": {
      "type": "string",
      "faker": "location.buildingNumber"
    },
    "poBox": {
      "type": "string"
    },
    "addressSupplement": {
      "type": "string"
    },
    "coSupplement": {
      "type": "string"
    },
    "countryCode": {
      "$ref": "../enum/CountryCode.schema.json"
    },
    "district": {
      "type": "string",
      "faker": "location.city"
    },
    "additionalInformation": {
      "$ref": "../com/AddressSupplementInformation.schema.json"
    }
  }
}