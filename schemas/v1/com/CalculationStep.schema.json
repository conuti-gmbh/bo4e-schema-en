          "min": 1,
          "max": 10
        }
      }
    },
    "lossFactorLine": {
      "type": "number",
      "format": "float",
      "faker": {
        "number.float": {
          "multipleOf": 0.25,
          "min": 1,
          "max": 10
        }
      }
    },
    "allocationFactorEnergyQuantity": {
      "type": "number",
      "format": "float",
      "faker": {
        "number.float": {
          "multipleOf": 0.25,
          "min": 1,
          "max": 10
        }
      }
    },
    "meteringLocationId": {
      "type": "string",
      "faker": {
        "string.numeric": 33
      }
