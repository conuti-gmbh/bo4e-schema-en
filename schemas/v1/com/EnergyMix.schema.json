{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/com/EnergyMix.schema.json",
  "title": "EnergyMix",
  "type": "object",
  "properties": {
    "share": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/EnergyOrigin.schema.json"
      }
    },
    "nuclearWaste": {
      "type": "number",
      "format": "float",
      "faker": {
        "number.float": {
          "multipleOf": 0.25,
          "min": 10,
          "max": 20
        }
      }
    },
    "remark": {
      "type": "string"
    },
    "designation": {
      "type": "string"
    },
    "co2Emission": {
      "type": "number",
      "format": "float",
      "faker": {
        "number.float": {
          "multipleOf": 0.25,
          "min": 10,
          "max": 20
        }
      }
    },
    "energyType": {
      "$ref": "../enum/Sector.schema.json"
    },
    "energyMixNumber": {
      "type": "integer",
      "faker": {
        "number.int": {
          "min": 1,
          "max": 10
        }
      }
    },
    "validityYear": {
      "type": "integer",
      "faker": {
        "number.int": {
          "min": 2024,
          "max": 2034
        }
      }
    },
    "isInEcoTopTen": {
      "type": "boolean"
    },
    "ecoLabel": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../enum/EcoLabel.schema.json"
      }
    },
    "ecoCertificates": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../enum/EcoCertificate.schema.json"
      }
    },
    "website": {
      "type": "string"
    }
  }
}