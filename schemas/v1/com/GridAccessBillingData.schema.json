{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema/master/schemas/v1/com/Netznutzungsabrechnungsdaten.schema.json",
  "title": "GridAccessBillingData",
  "type": "object",
  "properties": {
    "articleId": {
      "type": "string",
      "faker": {
        "string.numeric": 10
      },
