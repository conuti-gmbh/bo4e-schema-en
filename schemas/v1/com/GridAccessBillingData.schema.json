    },
    "articleIdType": {
      "$ref": "../enum/ArticleIdType.schema.json"
    },
    "quantity": {
      "type": "integer",
      "faker": {
        "number.int": {
          "min": 1,
          "max": 10
        }
      },
      "description": "Anzahl"
    },
    "municipalDiscount": {
      "type": "number",
      "format": "float",
      "faker": {
        "number.float": {
          "multipleOf": 0.25,
          "min": 1,
          "max": 10
        }
      },
      "description": "Gemeinderabatt"
    },
    "surcharge": {
      "type": "number",
      "format": "float",
      "faker": {
        "number.float": {
          "multipleOf": 0.25,
          "min": 1,
          "max": 10
        }
      },
      "description": "Zuschlag"
    },
    "installment": {
      "type": "number",
      "format": "float",
      "faker": {
        "number.float": {
          "multipleOf": 0.25,
          "min": 1,
          "max": 10
        }
      },
      "description": "Abschlag"
    },
    "singularEquipment": {
      "$ref": "../com/Quantity.schema.json"
    },
    "priceSingularEquipment": {
      "$ref": "../com/Price.schema.json"
    },
    "billingReactivePower": {
      "type": "boolean",
      "description": "abrechnungBlindarbeit"
