{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/com/GridAccessBillingData.schema.json",
  "title": "GridAccessBillingData",
  "type": "object",
  "properties": {
    "articleId": {
      "type": "string",
      "faker": {
        "string.numeric": 10
      }
    },
    "articleIdType": {
      "$ref": "../enum/ArticleIdType.schema.json"
    },
    "quantity": {
      "type": "integer",
      "faker": {
        "number.int": {
          "min": 1,
          "max": 10
        }
      }
    },
    "municipalDiscount": {
      "type": "number",
      "format": "float",
      "faker": {
        "number.float": {
          "multipleOf": 0.25,
          "min": 1,
          "max": 10
        }
      }
    },
    "surcharge": {
      "type": "number",
      "format": "float",
      "faker": {
        "number.float": {
          "multipleOf": 0.25,
          "min": 1,
          "max": 10
        }
      }
    },
    "installment": {
      "type": "number",
      "format": "float",
      "faker": {
        "number.float": {
          "multipleOf": 0.25,
          "min": 1,
          "max": 10
        }
      }
    },
    "singularEquipment": {
      "$ref": "../com/Quantity.schema.json"
    },
    "priceSingularEquipment": {
      "$ref": "../com/Price.schema.json"
    },
    "billingReactivePower": {
      "type": "boolean"
    },
    "payerReactivePower": {
      "$ref": "../enum/PayerReactivePower.schema.json"
    },
    "payerReactivePowerSupplier": {
      "type": "boolean"
    },
    "differenceData": {
      "type": "boolean"
    },
    "meteringTimes": {
      "$ref": "../com/MeteringTimeRegister.schema.json"
    }
  }
