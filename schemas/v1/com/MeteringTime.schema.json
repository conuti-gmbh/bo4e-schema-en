{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema/master/schemas/v1/com/Zaehlzeit.schema.json",
  "title": "MeteringTime",
  "type": "object",
  "properties": {
    "code": {
      "type": "string",
      "faker": {
        "string.binary": {
          "prefix": "CODE_",
          "length": 6
        }
      },
      "description": "Zählzeitdefinition"
    },
    "frequency": {
      "$ref": "../enum/MeteringTimeFrequency.schema.json",
      "description": "Häufigkeit der Übermittlung"
    },
    "transmissibility": {
      "$ref": "../enum/MeteringTimeTransmissibility.schema.json",
      "description": "Art der Übermittlung"
    },
    "peakLoadDetermination": {
      "$ref": "../enum/PeakLoadDetermination.schema.json",
      "description": "Ermittlung Leistungsmaximum"
    },
    "isOrderable": {
      "type": "boolean",
      "description": "Ist die Zählzeit bestellbar?"
    },
    "typeValue": {
      "$ref": "../enum/MeteringTimeDefinitionType.schema.json",
      "description": "ZählzeitdefinitionTyp"
    },
    "descriptionType": {
      "type": "string",
      "description": "Beschreibung des ZählzeitdefinitionTyp"
    },
    "changeTimestamp": {
      "type": "string",
      "format": "date-time",
      "description": "aenderungszeitpunkt"
    },
    "register": {
      "type": "string",
      "description": "register"
    }
  }
}