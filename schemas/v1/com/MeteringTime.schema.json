{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/com/MeteringTime.schema.json",
  "title": "MeteringTime",
  "type": "object",
  "properties": {
    "code": {
      "type": "string",
      "faker": {
        "string.binary": {
          "prefix": "CODE_",
          "length": 6
        }
      }
    },
    "frequency": {
      "$ref": "../enum/MeteringTimeFrequency.schema.json"
    },
    "transmissibility": {
      "$ref": "../enum/MeteringTimeTransmissibility.schema.json"
    },
    "peakLoadDetermination": {
      "$ref": "../enum/PeakLoadDetermination.schema.json"
    },
    "isOrderable": {
      "type": "boolean"
    },
    "typeValue": {
      "$ref": "../enum/MeteringTimeDefinitionType.schema.json"
    },
    "descriptionType": {
      "type": "string"
    },
    "changeTimestamp": {
      "type": "string",
      "format": "date-time"
    },
    "register": {
      "type": "string"
    }
  }
}