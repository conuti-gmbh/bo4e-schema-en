{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/com/MeterRegister.schema.json",
  "title": "MeterRegister",
  "type": "object",
  "properties": {
    "meterRegisterId": {
      "type": "string",
      "faker": {
        "string.numeric": 9
      }
    },
    "designation": {
      "type": "string"
    },
    "direction": {
      "$ref": "../enum/EnergyDirection.schema.json"
    },
    "obisCode": {
      "type": "string"
    },
    "transformerFactor": {
      "type": "number",
      "format": "float",
      "faker": {
        "number.float": {
          "multipleOf": 0.5,
          "min": 1,
          "max": 5
        }
      }
    },
    "unit": {
      "$ref": "../enum/QuantityUnit.schema.json"
    },
    "offPeakCapable": {
      "$ref": "../enum/OffPeakCapable.schema.json"
    },
    "consumptionType": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../enum/ConsumptionType.schema.json"
      }
    },
    "interruptibility": {
      "$ref": "../enum/Interruptibility.schema.json"
    },
    "heatUsage": {
      "$ref": "../enum/HeatUsage.schema.json"
    },
    "concessionFee": {
      "$ref": "../com/ConcessionFee.schema.json"
    },
    "taxExempt": {
      "type": "boolean"
    },
    "integerDigits": {
      "type": "integer",
      "faker": {
        "number.int": {
          "min": 1,
          "max": 9
        }
      }
    },
    "decimalPlaces": {
      "type": "integer",
      "faker": {
        "number.int": {
          "min": 1,
          "max": 9
        }
      }
    },
    "billingRelevant": {
      "type": "boolean"
    },
    "numberOfReadings": {
      "type": "integer",
      "faker": {
        "number.int": {
          "min": 1,
          "max": 9
        }
      }
    },
    "meteringTimes": {
      "$ref": "../com/MeteringTimeRegister.schema.json"
    },
    "configuration": {
      "type": "string"
    },
    "meteringProduct": {
      "type": "string"
    },
    "valueGranularity": {
      "$ref": "../enum/ValueGranularity.schema.json"
    },
    "necessitySecondMeasurement": {
      "$ref": "../enum/NecessitySecondMeasurement.schema.json"
    },
    "valueTransmissionPurpose": {
      "$ref": "../enum/ValueTransmissionPurpose.schema.json"
    },
    "typeElectricMobility": {
      "$ref": "../enum/TypeElectricMobility.schema.json"
    },
    "configurationProduct": {
      "type": "string"
    },
    "noConfigurationProduct": {
      "type": "boolean"
    },
    "loadCurveDefinition": {
      "type": "string"
    },
    "purposesOfUse": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/PurposeOfUse.schema.json"
      }
    }
  }
}