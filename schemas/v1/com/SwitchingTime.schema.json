{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema/master/schemas/v1/com/Leistungskurve.schema.json",
  "title": "SwitchingTime",
  "type": "object",
  "properties": {
    "code": {
      "type": "string",
      "faker": {
        "string.binary": {
          "prefix": "CODE_",
          "length": 6
        }
      },
      "description": "code"
    },
    "changeTimestamp": {
      "type": "string",
      "format": "date-time",
      "description": "aenderungszeitpunkt"
    },
    "frequency": {
      "$ref": "../enum/SwitchingTimeFrequency.schema.json"
    },
    "transmissibility": {
      "$ref": "../enum/SwitchingTimeTransmissibility.schema.json"
    },
    "switchingAction": {
      "$ref": "../enum/SwitchingAction.schema.json"
    },
    "configurationProduct": {
      "type": "string",
      "description": "konfigurationsprodukt"
    }
  }
}