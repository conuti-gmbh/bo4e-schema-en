{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/com/Discrepancy.schema.json",
  "title": "Discrepancy",
  "type": "object",
  "properties": {
    "discrepancyReason": {
      "$ref": "../enum/DiscrepancyReason.schema.json"
    },
    "discrepancyReasonNote": {
      "type": "string"
    },
    "associatedInvoice": {
      "type": "string",
      "faker": {
        "string.binary": {
          "prefix": "RN",
          "length": 6
        }
      }
    },
    "associatedOrder": {
      "type": "string",
      "faker": {
        "string.binary": {
          "prefix": "BEST",
          "length": 6
        }
      }
    },
    "discrepancyReasonCode": {
      "type": "string"
    },
    "discrepancyReasonCodeList": {
      "type": "string"
    },
    "missingPositions1": {
      "type": "string"
    },
    "missingPositions2": {
      "type": "string"
    },
    "missingPositions3": {
      "type": "string"
    },
    "missingPositions4": {
      "type": "string"
    },
    "missingPositions5": {
      "type": "string"
    },
    "discrepancyReasonNote1": {
      "type": "string"
    },
    "discrepancyReasonNote2": {
      "type": "string"
    },
    "discrepancyReasonNote3": {
      "type": "string"
    },
    "discrepancyReasonNote4": {
      "type": "string"
    },
    "discrepancyReasonNote5": {
      "type": "string"
    },
    "reference": {
      "type": "string",
      "faker": {
        "string.binary": {
          "prefix": "REF",
          "length": 6
        }
      }
    },
    "installmentInvoices": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    }
  }
}