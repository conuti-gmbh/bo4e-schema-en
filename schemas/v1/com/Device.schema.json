{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema/master/schemas/v1/com/Geraet.schema.json",
  "title": "Device",
  "type": "object",
  "properties": {
    "deviceType": {
      "$ref": "../enum/DeviceType.schema.json"
    },
    "designation": {
      "type": "string",
      "description": "Bezeichnung des Gerätes"
    },
    "deviceNumber": {
      "type": "string",
      "faker": {
        "string.numeric": 5
      },
      "description": "Die auf dem Geräte aufgedruckte Nummer, die vom MSB vergeben wird."
    },
    "deviceReference": {
      "type": "string",
      "faker": {
        "string.binary": {
          "prefix": "REF_",
          "length": 6
        }
      },
      "description": "geraetereferenz"
    },
    "deviceProperties": {
      "$ref": "../com/DeviceProperties.schema.json",
      "description": "Festlegung der Eigenschaften des Gerätes. Z.B. Wandler MS/NS."
    },
    "volumeCapture": {
      "$ref": "../enum/VolumeCapture.schema.json"
    },
    "additionalDeviceNumbers": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string",
        "faker": {
          "string.numeric": 5
        }
      },
      "description": "weitereGeraetenummern"
    }
  }
}