{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/com/Device.schema.json",
  "title": "Device",
  "type": "object",
  "properties": {
    "deviceType": {
      "$ref": "../enum/DeviceType.schema.json"
    },
    "designation": {
      "type": "string"
    },
    "deviceNumber": {
      "type": "string",
      "faker": {
        "string.numeric": 5
      }
    },
    "deviceReference": {
      "type": "string",
      "faker": {
        "string.binary": {
          "prefix": "REF_",
          "length": 6
        }
      }
    },
    "deviceProperties": {
      "$ref": "../com/DeviceProperties.schema.json"
    },
    "volumeCapture": {
      "$ref": "../enum/VolumeCapture.schema.json"
    },
    "additionalDeviceNumbers": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string",
        "faker": {
          "string.numeric": 5
        }
      }
    }
  }
}