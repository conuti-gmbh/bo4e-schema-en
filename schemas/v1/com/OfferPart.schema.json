{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema/master/schemas/v1/com/Angebotsteil.schema.json",
  "title": "OfferPart",
  "type": "object",
  "properties": {
    "requestSubReference": {
      "type": "string",
      "faker": {
        "string.binary": {
          "prefix": "ANSUBREF",
          "length": 4
        }
      },
      "description": "Referenz der ANfrage"
    },
    "offerPartTotalQuantity": {
      "$ref": "../com/Quantity.schema.json"
    },
    "offerPartTotalCosts": {
      "$ref": "../com/Amount.schema.json"
    },
    "deliveryPeriod": {
      "$ref": "../com/TimePeriod.schema.json"
    },
    "referenceCatalogNumber": {
      "$ref": "../com/CatalogReference.schema.json"
    },
    "deliveryPointOfferPart": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../bo/MarketLocation.schema.json"
      },
      "description": "Angebotsteil der Lieferstelle"
    },
    "positions": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/OfferPosition.schema.json"
      },
      "description": "Positionen des Angebots"
    }
  }
}