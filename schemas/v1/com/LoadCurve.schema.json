{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/com/LoadCurve.schema.json",
  "title": "LoadCurve",
  "type": "object",
  "properties": {
    "code": {
      "type": "string",
      "faker": {
        "string.binary": {
          "prefix": "CODE_",
          "length": 4
        }
      }
    },
    "changeTimestamp": {
      "type": "string",
      "format": "date-time"
    },
    "frequency": {
      "$ref": "../enum/LoadCurveFrequency.schema.json"
    },
    "transmissibility": {
      "$ref": "../enum/LoadCurveTransmissibility.schema.json"
    },
    "threshold": {
      "$ref": "../com/Threshold.schema.json"
    },
    "configurationProduct": {
      "type": "string",
      "faker": {
        "string.binary": {
          "prefix": "KONF_",
          "length": 4
        }
      }
    }
  }
}