{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema/master/schemas/v1/com/Leistungskurve.schema.json",
  "title": "LoadCurve",
  "type": "object",
  "properties": {
    "code": {
      "type": "string",
      "faker": {
        "string.binary": {
          "prefix": "CODE_",
          "length": 4
        }
      },
      "description": "Code der Leistungskurve"
    },
    "changeTimestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Änderungszeitpunkt"
    },
    "frequency": {
      "$ref": "../enum/LoadCurveFrequency.schema.json"
    },
    "transmissibility": {
      "$ref": "../enum/LoadCurveTransmissibility.schema.json"
    },
    "threshold": {
      "$ref": "../com/Threshold.schema.json"
    },
    "configurationProduct": {
      "type": "string",
      "faker": {
        "string.binary": {
          "prefix": "KONF_",
          "length": 4
        }
      },
      "description": "Konfigurationsprodukt"
    }
  }
}