{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/com/PricePosition.schema.json",
  "title": "PricePosition",
  "type": "object",
  "properties": {
    "calculationMethod": {
      "$ref": "../enum/CalculationMethod.schema.json"
    },
    "performanceType": {
      "$ref": "../enum/PerformanceType.schema.json"
    },
    "serviceDesignation": {
      "$ref": "../enum/ServiceDesignation.schema.json"
    },
    "priceUnit": {
      "$ref": "../enum/CurrencyUnit.schema.json"
    },
    "referenceQuantity": {
      "$ref": "../enum/QuantityUnit.schema.json"
    },
    "timeBasis": {
      "$ref": "../enum/TimeUnit.schema.json"
    },
    "tariffTime": {
      "$ref": "../enum/TariffTime.schema.json"
    },
    "bdewArticleNumber": {
      "$ref": "../enum/BDEWArticleNumber.schema.json"
    },
    "zoningSize": {
      "$ref": "../enum/MeasurementQuantity.schema.json"
    },
    "priceKeyMaster": {
      "type": "string"
    },
    "positionNumber": {
      "type": "integer",
      "faker": {
        "number.int": {
          "min": 1,
          "max": 10
        }
      }
    },
    "meteringLevel": {
      "$ref": "../enum/GridLevel.schema.json"
    },
    "description": {
      "type": "string"
    },
    "descriptionFormat": {
      "$ref": "../enum/DescriptionFormat.schema.json"
    },
    "processingPeriod": {
      "$ref": "../com/TimePeriod.schema.json"
    },
    "articleId": {
      "type": "string",
      "faker": {
        "string.numeric": 10
      }
    },
    "surchargesDiscounts": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/PositionSurchargeDiscount.schema.json"
      }
    },
    "priceSteps": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/PriceTier.schema.json"
      }
    }
  }
}