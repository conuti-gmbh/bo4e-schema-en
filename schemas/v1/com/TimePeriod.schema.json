{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema/master/schemas/v1/com/Zeitraum.schema.json",
  "title": "TimePeriod",
  "type": "object",
  "properties": {
    "timeUnit": {
      "$ref": "../enum/TimeUnit.schema.json"
    },
    "duration": {
      "type": "integer",
      "faker": {
        "number.int": 10
      },
      "description": "dauer"
    },
    "startDate": {
      "type": "string",
      "format": "date-time",
      "description": "startdatum"
    },
    "endDate": {
      "type": "string",
      "format": "date-time",
      "description": "enddatum"
    },
    "unit": {
      "$ref": "../enum/TimeUnit.schema.json"
    },
    "readingPeriod": {
      "type": "string",
      "faker": {
        "string.numeric": 6
      },
      "description": "ableseZeitraum"
    },
    "billingPeriod": {
      "type": "string",
      "faker": {
        "string.numeric": 6
      },
      "description": "abrechnungsZeitraum"
    },
    "periodText": {
      "type": "string",
      "description": "zeitraumText"
    },
    "periodId": {
      "type": "integer",
      "faker": {
        "number.int": {
          "min": 1,
          "max": 9
        }
      },
      "description": "zeitraumId"
    }
  }
}