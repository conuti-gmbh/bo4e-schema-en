{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/com/TimePeriod.schema.json",
  "title": "TimePeriod",
  "type": "object",
  "properties": {
    "timeUnit": {
      "$ref": "../enum/TimeUnit.schema.json"
    },
    "duration": {
      "type": "integer",
      "faker": {
        "number.int": 10
      }
    },
    "startDate": {
      "type": "string",
      "format": "date-time"
    },
    "endDate": {
      "type": "string",
      "format": "date-time"
    },
    "unit": {
      "$ref": "../enum/TimeUnit.schema.json"
    },
    "readingPeriod": {
      "type": "string",
      "faker": {
        "string.numeric": 6
      }
    },
    "billingPeriod": {
      "type": "string",
      "faker": {
        "string.numeric": 6
      }
    },
    "periodText": {
      "type": "string"
    },
    "periodId": {
      "type": "integer",
      "faker": {
        "number.int": {
          "min": 1,
          "max": 9
        }
      }
    }
  }
}