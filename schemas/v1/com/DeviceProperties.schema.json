{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/com/DeviceProperties.schema.json",
  "title": "DeviceProperties",
  "type": "object",
  "properties": {
    "deviceType": {
      "$ref": "../enum/DeviceType.schema.json"
    },
    "deviceAttribute": {
      "$ref": "../enum/DeviceAttribute.schema.json"
    },
    "volumeCapture": {
      "$ref": "../enum/VolumeCapture.schema.json"
    },
    "serialNumber": {
      "type": "string",
      "faker": {
        "string.numeric": 10
      }
    },
    "manufacturingDate": {
      "type": "string",
      "faker": {
        "string.numeric": 4
      }
    },
    "yearOfConstruction": {
      "type": "string",
      "faker": {
        "string.numeric": 4
      }
    },
    "calibrationUntil": {
      "type": "string",
      "faker": {
        "string.numeric": 4
      }
    },
    "factor": {
      "type": "number",
      "format": "float",
      "faker": {
        "number.float": {
          "multipleOf": 0.25,
          "min": 1,
          "max": 10
        }
      }
    },
    "firmwareVersion": {
      "type": "string",
      "faker": {
        "string.binary": {
          "prefix": "FW_",
          "length": 4
        }
      }
    },
    "manufacturerTypeDesignation": {
      "type": "string",
      "faker": {
        "string.binary": {
          "prefix": "TYP_",
          "length": 6
        }
      }
    },
    "simCardNumber": {
      "type": "string",
      "faker": {
        "string.numeric": 20
      }
    },
    "modemIdentifierIMSI": {
      "type": "string",
      "faker": {
        "string.numeric": 15
      }
    },
    "telecommunicationsProvider": {
      "type": "string",
      "faker": {
        "string.binary": {
          "prefix": "TK_",
          "length": 4
        }
      }
    },
    "ipVersion": {
      "type": "string",
      "faker": {
        "string.numeric": 1
      }
    }
  }
}