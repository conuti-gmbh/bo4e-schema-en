{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/com/ContractConditions.schema.json",
  "title": "ContractConditions",
  "type": "object",
  "properties": {
    "gridAccessPayer": {
      "$ref": "../enum/GridAccessPayer.schema.json"
    },
    "gridAccessContract": {
      "$ref": "../enum/GridAccessContract.schema.json"
    },
    "gridAccessBilling": {
      "$ref": "../com/TimePeriod.schema.json"
    },
    "includesSingularlyUsedEquipment": {
      "type": "boolean"
    },
    "gridAccessBillingBasis": {
      "$ref": "../enum/GridAccessBillingBasis.schema.json"
    },
    "gridAccessBillingVariant": {
      "$ref": "../enum/GridAccessBillingVariant.schema.json"
    },
    "householdCustomer": {
      "type": "boolean"
    },
    "billingViaNna": {
      "type": "boolean"
    },
    "municipalDiscount": {
      "$ref": "../com/MunicipalDiscount.schema.json"
    },
    "billingYearStart": {
      "type": "string",
      "format": "date-time"
    },
    "nextGridAccessBilling": {
      "type": "string",
      "faker": {
        "string.numeric": 4
      }
    },
    "billingInterval": {
      "type": "integer",
      "faker": {
        "number.int": {
          "min": 1,
          "max": 5
        }
      }
    },
    "gridAccessBillingInterval": {
      "type": "integer",
      "faker": {
        "number.int": {
          "min": 1,
          "max": 5
        }
      }
    },
    "plannedScheduledReading": {
      "$ref": "../com/TimePeriod.schema.json"
    },
    "msbCommissioning": {
      "$ref": "../enum/MsbCommissioning.schema.json"
    },
    "terminationNotice": {
      "$ref": "../com/TimePeriod.schema.json"
    },
    "contractDuration": {
      "$ref": "../com/TimePeriod.schema.json"
    },
    "terminationDate": {
      "type": "string"
    },
    "installmentCycle": {
      "$ref": "../com/TimePeriod.schema.json"
    },
    "numberOfInstallments": {
      "type": "number",
      "format": "float",
      "faker": {
        "number.float": {
          "multipleOf": 1,
          "min": 1,
          "max": 12
        }
      }
    },
    "description": {
      "type": "string"
    },
    "contractExtension": {
      "$ref": "../com/TimePeriod.schema.json"
    }
  }
}