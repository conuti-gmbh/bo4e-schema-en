{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/com/AdviceNotePosition.schema.json",
  "title": "AdviceNotePosition",
  "type": "object",
  "properties": {
    "invoiceNumber": {
      "type": "string",
      "faker": {
        "string.numeric": 11
      }
    },
    "billingDate": {
      "type": "string",
      "format": "date-time"
    },
    "isCancellation": {
      "type": "boolean"
    },
    "isSelfIssued": {
      "type": "boolean"
    },
    "totalGross": {
      "$ref": "../com/Amount.schema.json"
    },
    "toPay": {
      "$ref": "../com/Amount.schema.json"
    },
    "reference": {
      "type": "string",
      "faker": {
        "string.binary": {
          "prefix": "REF",
          "length": 6
        }
      }
    },
    "discrepancy": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/Discrepancy.schema.json"
      }
    },
    "positions": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/FeedbackPosition.schema.json"
      }
    }
  }
}