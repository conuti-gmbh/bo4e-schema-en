{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema/master/schemas/v1/com/Avisposition.schema.json",
  "title": "AdviceNotePosition",
  "type": "object",
  "properties": {
    "invoiceNumber": {
      "type": "string",
      "faker": {
        "string.numeric": 11
      },
      "description": "rechnungsNummer"
    },
    "billingDate": {
      "type": "string",
      "format": "date-time",
      "description": "rechnungsDatum"
    },
    "isCancellation": {
      "type": "boolean",
      "description": "istStorno"
    },
    "isSelfIssued": {
      "type": "boolean",
      "description": "istSelbstausgestellt"
    },
    "totalGross": {
      "$ref": "../com/Amount.schema.json"
    },
    "toPay": {
      "$ref": "../com/Amount.schema.json"
    },
    "reference": {
      "type": "string",
      "faker": {
        "string.binary": {
          "prefix": "REF",
          "length": 6
        }
      },
      "description": "referenz"
    },
    "discrepancy": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/Discrepancy.schema.json"
      },
      "description": "abweichung"
    },
    "positions": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/FeedbackPosition.schema.json"
      },
      "description": "positionen"
    }
  }
}