{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/com/OfferPosition.schema.json",
  "title": "OfferPosition",
  "type": "object",
  "properties": {
    "positionDesignation": {
      "type": "string"
    },
    "itemQuantity": {
      "$ref": "../com/Quantity.schema.json"
    },
    "positionPrice": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/Price.schema.json"
      }
    },
    "positionAmount": {
      "$ref": "../com/Amount.schema.json"
    },
    "priceKeyMaster": {
      "type": "string"
    },
    "articleNumber": {
      "$ref": "../enum/BDEWArticleNumber.schema.json"
    },
    "articleId": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "offerable": {
      "type": "boolean"
    },
    "freeText": {
      "type": "string"
    },
    "referenceCatalogNumber": {
      "$ref": "../com/CatalogReference.schema.json"
    },
    "involvedMarketPartner": {
      "$ref": "../bo/MarketParticipant.schema.json"
    },
    "referenceMarketLocationIds": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    }
  }
}