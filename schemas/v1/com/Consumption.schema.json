{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema/master/schemas/v1/com/Verbrauch.schema.json",
  "title": "Consumption",
  "type": "object",
  "properties": {
    "startDate": {
      "type": "string",
      "format": "date-time",
      "description": "startdatum"
    },
    "endDate": {
      "type": "string",
      "format": "date-time",
      "description": "enddatum"
    },
    "valueDeterminationMethod": {
      "$ref": "../enum/ValueDeterminationMethod.schema.json"
    },
    "measurementValueStatus": {
      "$ref": "../enum/MeasurementValueStatus.schema.json"
    },
    "obisNumber": {
      "type": "string",
      "description": "obiskennzahl"
    },
    "value": {
      "type": "number",
      "format": "float",
      "faker": {
        "number.float": {
          "multipleOf": 0.25,
          "min": 10,
          "max": 20
        }
      },
      "description": "wert"
    },
    "unit": {
      "$ref": "../enum/QuantityUnit.schema.json"
    },
    "type": {
      "$ref": "../enum/ConsumptionQuantityType.schema.json"
    },
    "tariffLevel": {
      "$ref": "../enum/TariffLevel.schema.json"
    },
    "usageTimestamp": {
      "type": "string",
      "format": "date-time",
      "description": "nutzungszeitpunkt"
    },
    "executionTimestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ausfuehrungszeitpunkt"
    },
    "position": {
      "type": "integer",
      "faker": {
        "string.numeric": 10
      },
      "description": "position"
    },
    "readingDate": {
      "type": "string",
      "format": "date-time",
      "description": "ablesedatum"
    },
    "servicePeriod": {
      "type": "string",
      "faker": {
        "string.numeric": 6
      },
      "description": "leistungsperiode"
    },
    "statusAdditionalInformation": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/StatusAdditionalInformation.schema.json"
      },
      "description": "statuszusatzinformationen"
    }
  }
}