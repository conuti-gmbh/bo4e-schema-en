{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema/master/schemas/v1/bo/Verwendungszeitraum.schema.json",
  "title": "UsagePeriod",
  "type": "object",
  "properties": {
    "boType": {
      "$ref": "../enum/BOType.schema.json",
      "default": "USAGE_PERIOD"
    },
    "structureVersion": {
      "type": "string",
      "default": "1",
      "description": "versionStruktur"
    },
    "usageFrom": {
      "type": "string",
      "format": "date-time",
      "description": "verwendungAb"
    },
    "usageTo": {
      "type": "string",
      "format": "date-time",
      "description": "verwendungBis"
    },
    "periodId": {
      "type": "integer",
      "faker": {
        "number.int": {
          "min": 1,
          "max": 9
        }
      },
      "description": "zeitraumId"
    },
    "dataQuality": {
      "$ref": "../enum/DataQuality.schema.json"
    }
  },
  "required": [
    "boType",
    "structureVersion"
  ]
}