{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/bo/Invoice.schema.json",
  "title": "Invoice",
  "type": "object",
  "properties": {
    "boType": {
      "$ref": "../enum/BOType.schema.json",
      "default": "INVOICE"
    },
    "structureVersion": {
      "type": "string",
      "default": "1"
    },
    "isSelfIssued": {
      "type": "boolean"
    },
    "processingDate": {
      "type": "string",
      "format": "date-time"
    },
    "invoiceDate": {
      "type": "string",
      "format": "date-time"
    },
    "dueDate": {
      "type": "string",
      "format": "date-time"
    },
    "invoiceStatus": {
      "$ref": "../enum/InvoiceStatus.schema.json"
    },
    "provisionalBillingPeriod": {
      "$ref": "../com/TimePeriod.schema.json"
    },
    "invoicePeriod": {
      "$ref": "../com/TimePeriod.schema.json"
    },
    "invoiceType": {
      "$ref": "../enum/InvoiceType.schema.json"
    },
    "isReverseCharge": {
      "type": "boolean"
    },
    "totalGrossAmount": {
      "$ref": "../com/Amount.schema.json"
    },
    "toPay": {
      "$ref": "../com/Amount.schema.json"
    },
    "originalInvoiceNumber": {
      "type": "string",
      "faker": {
        "string.binary": {
          "prefix": "RN_",
          "length": 6
        }
      }
    },
    "referenceMessageDate": {
      "type": "string",
      "faker": {
        "string.binary": {
          "prefix": "REF_",
          "length": 6
        }
      }
    },
    "referenceDocumentNumber": {
      "type": "string",
      "faker": {
        "string.binary": {
          "prefix": "DOC_",
          "length": 6
        }
      }
    },
    "referencePredecessorInvoice": {
      "type": "string",
      "faker": {
        "string.binary": {
          "prefix": "RN_",
          "length": 6
        }
      }
    },
    "predecessorInvoiceDate": {
      "type": "string",
      "format": "date-time"
    },
    "priceGridOperatorCodeNumber": {
      "type": "string"
    },
    "gridAccount": {
      "type": "string"
    },
    "prepaid": {
      "$ref": "../com/Amount.schema.json"
    },
    "municipalDiscount": {
      "$ref": "../com/MunicipalDiscount.schema.json"
    },
    "executionDate": {
      "type": "string",
      "format": "date-time"
    },
    "specialBillingType": {
      "$ref": "../enum/SpecialBillingType.schema.json"
    },
    "specialBillingTypes": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../enum/SpecialBillingType.schema.json"
      }
    },
    "energyDirection": {
      "$ref": "../enum/EnergyDirection.schema.json"
    },
    "balancingPeriodStart": {
      "type": "string",
      "format": "date-time"
    },
    "gridAccessPeriodEnd": {
      "type": "string",
      "format": "date-time"
    },
    "taxAmounts": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/TaxAmount.schema.json"
      }
    },
    "invoicePositions": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/InvoicePosition.schema.json"
      }
    }
  },
  "required": [
    "boType",
    "structureVersion"
  ]
}