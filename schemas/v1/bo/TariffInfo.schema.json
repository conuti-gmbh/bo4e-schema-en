{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/bo/TariffInfo.schema.json",
  "title": "TariffInfo",
  "type": "object",
  "properties": {
    "boType": {
      "$ref": "../enum/BOType.schema.json",
      "default": "TARIFF_INFO"
    },
    "structureVersion": {
      "type": "string",
      "default": "1"
    },
    "provider": {
      "$ref": "../bo/MarketParticipant.schema.json"
    },
    "providerName": {
      "type": "string"
    },
    "applicableFrom": {
      "type": "string",
      "format": "date-time"
    },
    "remark": {
      "type": "string"
    },
    "designation": {
      "type": "string"
    },
    "energyMix": {
      "$ref": "../com/EnergyMix.schema.json"
    },
    "customerTypes": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../enum/CustomerType.schema.json"
      }
    },
    "numberOfRegisters": {
      "$ref": "../enum/NumberOfRegisters.schema.json"
    },
    "sector": {
      "$ref": "../enum/Sector.schema.json"
    },
    "tariffAttributes": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../enum/TariffAttribute.schema.json"
      }
    },
    "tariffCategory": {
      "$ref": "../enum/TariffCategory.schema.json"
    },
    "contractConditions": {
      "$ref": "../com/ContractConditions.schema.json"
    },
    "website": {
      "type": "string"
    },
    "temporalValidity": {
      "$ref": "../com/TimePeriod.schema.json"
    }
  },
  "required": [
    "boType",
    "structureVersion"
  ]
}