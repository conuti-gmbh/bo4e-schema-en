{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/bo/MeteringLocation.schema.json",
  "title": "MeteringLocation",
  "type": "object",
  "properties": {
    "boType": {
      "$ref": "../enum/BOType.schema.json",
      "default": "METERING_LOCATION"
    },
    "structureVersion": {
      "type": "string",
      "default": "1"
    },
    "meteringLocationId": {
      "type": "string",
      "faker": {
        "string.numeric": 33
      }
    },
    "sector": {
      "$ref": "../enum/Sector.schema.json"
    },
    "energyDirection": {
      "$ref": "../enum/EnergyDirection.schema.json"
    },
    "meteringGridLevel": {
      "$ref": "../enum/GridLevel.schema.json"
    },
    "meteringAreaNumber": {
      "type": "string",
      "faker": {
        "string.numeric": 10
      }
    },
    "responsibleMsbCodeNumber": {
      "type": "string",
      "faker": {
        "string.numeric": 10
      }
    },
    "meteringAddress": {
      "$ref": "../com/Address.schema.json"
    },
    "balancingMethod": {
      "$ref": "../enum/BalancingMethod.schema.json"
    },
    "meteringPointOperationBillingNna": {
      "type": "boolean"
    },
    "gasQuality": {
      "$ref": "../enum/GasQuality.schema.json"
    },
    "lossFactor": {
      "type": "number",
      "format": "float",
      "faker": {
        "number.float": {
          "multipleOf": 0.25,
          "min": 1,
          "max": 10
        }
      }
    },
    "operationalState": {
      "$ref": "../enum/OperationalState.schema.json"
    },
    "readingCardRecipient": {
      "$ref": "../bo/BusinessPartner.schema.json"
    },
    "referenceMarketLocationId": {
      "type": "string",
      "faker": {
        "string.numeric": 11
      }
    },
    "usageScope": {
      "$ref": "../enum/UsageScope.schema.json"
    },
    "futureReportingPoint": {
      "type": "boolean"
    },
    "locationAssignment": {
      "$ref": "../enum/LocationAssignment.schema.json"
    },
    "involvedMarketPartner": {
      "$ref": "../bo/MarketParticipant.schema.json"
    },
    "devices": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/Device.schema.json"
      }
    },
    "meteringService": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/Service.schema.json"
      }
    },
    "meteringLocationMeter": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string",
        "faker": {
          "string.binary": {
            "prefix": "ZAEHLER_",
            "length": 3
          }
        }
      }
    },
    "meterRegisters": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/MeterRegister.schema.json"
      }
    },
    "marketRoles": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../bo/MarketParticipant.schema.json"
      }
    },
    "dataQuality": {
      "$ref": "../enum/DataQuality.schema.json"
    },
    "validityPeriod": {
      "$ref": "../com/TimePeriod.schema.json"
    }
  },
  "required": [
    "boType",
    "structureVersion"
  ]
}