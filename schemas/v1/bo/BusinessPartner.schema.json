{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/bo/BusinessPartner.schema.json",
  "title": "BusinessPartner",
  "type": "object",
  "properties": {
    "boType": {
      "$ref": "../enum/BOType.schema.json",
      "default": "BUSINESS_PARTNER"
    },
    "structureVersion": {
      "type": "string",
      "default": "1"
    },
    "salutation": {
      "type": "string",
      "faker": "person.prefix"
    },
    "name1": {
      "type": "string",
      "faker": "person.lastName"
    },
    "name2": {
      "type": "string",
      "faker": "person.firstName"
    },
    "name3": {
      "type": "string"
    },
    "name4": {
      "type": "string"
    },
    "vatId": {
      "type": "string",
      "faker": {
        "string.binary": {
          "prefix": "DE",
          "length": 9
        }
      }
    },
    "creditorId": {
      "type": "string",
      "faker": {
        "string.numeric": 6
      }
    },
    "emailAddress": {
      "type": "string",
      "faker": "internet.email"
    },
    "website": {
      "type": "string",
      "faker": "internet.url"
    },
    "commercialClassification": {
      "type": "boolean"
    },
    "commercialRegisterNumber": {
      "type": "string",
      "faker": {
        "string.numeric": 6
      }
    },
    "courtOfRegistration": {
      "type": "string",
      "faker": "location.city"
    },
    "partnerAddress": {
      "$ref": "../com/Address.schema.json"
    },
    "externalCustomerNumberSupplier": {
      "type": "string",
      "faker": {
        "string.numeric": 6
      }
    },
    "externalReferences": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/ExternalReference.schema.json"
      }
    },
    "businessPartnerRole": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../enum/BusinessPartnerRole.schema.json"
      }
    },
    "contactChannel": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../enum/ContactType.schema.json"
      }
    },
    "contactPerson": {
      "$ref": "../bo/ContactPerson.schema.json"
    }
  },
  "required": [
    "boType",
    "structureVersion"
  ]
}