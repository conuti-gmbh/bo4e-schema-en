{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/bo/ValuesByType2.schema.json",
  "title": "ValuesByType2",
  "type": "object",
  "properties": {
    "boType": {
      "$ref": "../enum/BOType.schema.json",
      "default": "VALUES_BY_TYPE2"
    },
    "structureVersion": {
      "type": "string",
      "default": "1"
    },
    "configurationProduct": {
      "type": "string"
    },
    "meteringProduct": {
      "type": "string"
    },
    "targetAddress": {
      "$ref": "../com/TargetAddress.schema.json"
    },
    "issuer": {
      "$ref": "../com/Issuer.schema.json"
    },
    "certificateUser": {
      "$ref": "../com/CertificateUser.schema.json"
    },
    "configurationChangeOption": {
      "$ref": "../enum/ConfigurationChangeOption.schema.json"
    },
    "thresholds": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/Threshold.schema.json"
      }
    },
    "meterRegisters": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/MeterRegister.schema.json"
      }
    }
  },
  "required": [
    "boType",
    "structureVersion"
  ]
}