{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema/master/schemas/v1/bo/WerteNachTyp2.schema.json",
  "title": "ValuesByType2",
  "type": "object",
  "properties": {
    "boType": {
      "$ref": "../enum/BOType.schema.json",
      "default": "VALUES_BY_TYPE2"
    },
    "structureVersion": {
      "type": "string",
      "default": "1",
      "description": "versionStruktur"
    },
    "configurationProduct": {
      "type": "string",
      "description": "konfigurationsprodukt"
    },
    "meteringProduct": {
      "type": "string",
      "description": "messprodukt"
    },
    "targetAddress": {
      "$ref": "../com/TargetAddress.schema.json"
    },
    "issuer": {
      "$ref": "../com/Issuer.schema.json"
    },
    "certificateUser": {
      "$ref": "../com/CertificateUser.schema.json"
    },
    "configurationChangeOption": {
      "$ref": "../enum/ConfigurationChangeOption.schema.json"
    },
    "thresholds": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/Threshold.schema.json"
      },
      "description": "schwellwerte"
    },
    "meterRegisters": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/MeterRegister.schema.json"
      },
      "description": "Zählwerke"
    }
  },
  "required": [
    "boType",
    "structureVersion"
  ]
}