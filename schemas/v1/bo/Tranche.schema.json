{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/bo/Tranche.schema.json",
  "title": "Tranche",
  "type": "object",
  "properties": {
    "boType": {
      "$ref": "../enum/BOType.schema.json",
      "default": "TRANCHE"
    },
    "structureVersion": {
      "type": "string",
      "default": "1"
    },
    "trancheId": {
      "type": "string",
      "faker": {
        "string.numeric": 11
      }
    },
    "sector": {
      "$ref": "../enum/Sector.schema.json"
    },
    "energyDirection": {
      "$ref": "../enum/EnergyDirection.schema.json"
    },
    "balancingMethod": {
      "$ref": "../enum/BalancingMethod.schema.json"
    },
    "consumptionType": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../enum/ConsumptionType.schema.json"
      }
    },
    "interruptible": {
      "type": "boolean"
    },
    "gridLevel": {
      "$ref": "../enum/GridLevel.schema.json"
    },
    "gridOperatorCodeNumber": {
      "type": "string"
    },
    "areaType": {
      "$ref": "../enum/AreaType.schema.json"
    },
    "gridAreaNumber": {
      "type": "string"
    },
    "balancingArea": {
      "type": "string"
    },
    "defaultSupplierCodeNumber": {
      "type": "string"
    },
    "gasQuality": {
      "$ref": "../enum/GasQuality.schema.json"
    },
    "endCustomer": {
      "$ref": "../bo/BusinessPartner.schema.json"
    },
    "locationAddress": {
      "$ref": "../com/Address.schema.json"
    },
    "cadastralInformation": {
      "$ref": "../com/CadastralAddress.schema.json"
    },
    "controlZone": {
      "type": "string"
    },
    "marketArea": {
      "type": "string"
    },
    "timeSeriesType": {
      "$ref": "../enum/TimeSeriesType.schema.json"
    },
    "meteringTechnicalClassification": {
      "$ref": "../enum/MeteringTechnicalClassification.schema.json"
    },
    "lockStatus": {
      "$ref": "../enum/LockStatus.schema.json"
    },
    "referenceMarketLocationId": {
      "type": "string",
      "faker": {
        "string.numeric": 11
      }
    },
    "supplyType": {
      "$ref": "../enum/SupplyType.schema.json"
    },
    "remoteControllability": {
      "$ref": "../enum/RemoteControllability.schema.json"
    },
    "compensationRecipient": {
      "$ref": "../enum/CompensationRecipient.schema.json"
    },
    "promotionCountry": {
      "type": "string"
    },
    "statusGeneratingMalo": {
      "$ref": "../enum/StatusGeneratingMarketLocation.schema.json"
    },
    "referenceTranche": {
      "type": "string",
      "faker": {
        "string.numeric": 11
      }
    },
    "allocationQuantity": {
      "$ref": "../com/Quantity.schema.json"
    },
    "balancingGroup": {
      "type": "string"
    },
    "trancheFormationSize": {
      "$ref": "../enum/TrancheFormationSize.schema.json"
    },
    "futureReportingPoint": {
      "type": "boolean"
    },
    "locationAssignment": {
      "$ref": "../enum/LocationAssignment.schema.json"
    },
    "involvedMarketPartner": {
      "$ref": "../bo/MarketParticipant.schema.json"
    },
    "marketRoles": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../bo/MarketParticipant.schema.json"
      }
    },
    "meterRegisters": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/MeterRegister.schema.json"
      }
    },
    "meterRegistersInvolvedMarketRole": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../enum/MarketRole.schema.json"
      }
    },
    "consumptionQuantity": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/Consumption.schema.json"
      }
    },
    "associatedMeteringLocations": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/MeteringLocationAssignment.schema.json"
      }
    },
    "gridAccessBillingData": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/GridAccessBillingData.schema.json"
      }
    },
    "energyOrigin": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/EnergyOrigin.schema.json"
      }
    },
    "dataQuality": {
      "$ref": "../enum/DataQuality.schema.json"
    },
    "validityPeriod": {
      "$ref": "../com/TimePeriod.schema.json"
    }
  },
  "required": [
    "boType",
    "structureVersion"
  ]
}