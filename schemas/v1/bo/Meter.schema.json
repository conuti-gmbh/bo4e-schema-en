{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/bo/Meter.schema.json",
  "title": "Meter",
  "type": "object",
  "properties": {
    "boType": {
      "$ref": "../enum/BOType.schema.json",
      "default": "METER"
    },
    "structureVersion": {
      "type": "string",
      "default": "1"
    },
    "meterNumber": {
      "type": "string",
      "faker": {
        "string.binary": {
          "prefix": "ZAEHLER_",
          "length": 6
        }
      }
    },
    "sector": {
      "$ref": "../enum/Sector.schema.json"
    },
    "meterCharacteristic": {
      "$ref": "../enum/MeterCharacteristic.schema.json"
    },
    "meterType": {
      "$ref": "../enum/MeterType.schema.json"
    },
    "tariffType": {
      "$ref": "../enum/TariffType.schema.json"
    },
    "meterConstant": {
      "type": "number",
      "format": "float",
      "faker": {
        "number.float": {
          "multipleOf": 0.5,
          "min": 10,
          "max": 30
        }
      }
    },
    "calibrationUntil": {
      "type": "string",
      "faker": {
        "string.numeric": 4
      }
    },
    "meterManufacturer": {
      "$ref": "../bo/BusinessPartner.schema.json"
    },
    "gateway": {
      "type": "string",
      "faker": {
        "string.binary": {
          "prefix": "GATEWAY_",
          "length": 6
        }
      }
    },
    "remoteSwitch": {
      "$ref": "../enum/RemoteSwitch.schema.json"
    },
    "measurementValueCapture": {
      "$ref": "../enum/MeasurementValueCapture.schema.json"
    },
    "meterTypeSpecification": {
      "$ref": "../enum/MeterTypeSpecification.schema.json"
    },
    "mountingType": {
      "$ref": "../enum/MountingType.schema.json"
    },
    "meterSize": {
      "$ref": "../enum/DeviceAttribute.schema.json"
    },
    "quantityConverterType": {
      "$ref": "../enum/QuantityConverterType.schema.json"
    },
    "volumeCapture": {
      "$ref": "../enum/VolumeCapture.schema.json"
    },
    "serialNumber": {
      "type": "string",
      "faker": {
        "string.numeric": 10
      }
    },
    "deviceAttribute": {
      "$ref": "../enum/DeviceAttribute.schema.json"
    },
    "manufacturingDate": {
      "type": "string",
      "faker": {
        "string.numeric": 4
      }
    },
    "yearOfConstruction": {
      "type": "string",
      "faker": {
        "string.numeric": 4
      },
      "$comment": "DTM+Z03"
    },
    "meteringLocationId": {
      "type": "string",
      "faker": {
        "string.numeric": 33
      }
    },
    "marketLocationId": {
      "type": "string",
      "faker": {
        "string.numeric": 11
      }
    },
    "devices": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/Device.schema.json"
      }
    },
    "meterRegisters": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/MeterRegister.schema.json"
      }
    },
    "dataQuality": {
      "$ref": "../enum/DataQuality.schema.json"
    },
    "validityPeriod": {
      "$ref": "../com/TimePeriod.schema.json"
    }
  },
  "required": [
    "boType",
    "structureVersion"
  ]
}