{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/bo/EnergyQuantity.schema.json",
  "title": "EnergyQuantity",
  "type": "object",
  "properties": {
    "boType": {
      "$ref": "../enum/BOType.schema.json",
      "default": "ENERGY_QUANTITY"
    },
    "structureVersion": {
      "type": "string",
      "default": "1"
    },
    "locationId": {
      "type": "string",
      "faker": {
        "string.numeric": 11
      }
    },
    "locationType": {
      "$ref": "../enum/LocationType.schema.json"
    },
    "completionDate": {
      "type": "string",
      "format": "date-time"
    },
    "startDate": {
      "type": "string",
      "format": "date-time"
    },
    "endDate": {
      "type": "string",
      "format": "date-time"
    },
    "balancingDate": {
      "type": "string",
      "format": "date-time"
    },
    "beginDate": {
      "type": "string",
      "format": "date-time"
    },
    "referenceMasterDataNotificationMsb": {
      "type": "string",
      "faker": {
        "string.binary": {
          "prefix": "REF",
          "length": 6
        }
      }
    },
    "configuration": {
      "type": "string"
    },
    "energyConsumption": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/Consumption.schema.json"
      }
    }
  },
  "required": [
    "boType",
    "structureVersion"
  ]
}