{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema/master/schemas/v1/bo/Energiemenge.schema.json",
  "title": "EnergyQuantity",
  "type": "object",
  "properties": {
    "boType": {
      "$ref": "../enum/BOType.schema.json",
      "default": "ENERGY_QUANTITY"
    },
    "structureVersion": {
      "type": "string",
      "default": "1",
      "description": "versionStruktur"
    },
    "locationId": {
      "type": "string",
      "faker": {
        "string.numeric": 11
      },
      "description": "Eindeutige Nummer der Marktlokation bzw. der Messlokation, zu der die Energiemenge gehört"
    },
    "locationType": {
      "$ref": "../enum/LocationType.schema.json",
      "description": "Gibt an, ob es sich um eine Markt- oder Messlokation handelt."
    },
    "completionDate": {
      "type": "string",
      "format": "date-time",
      "description": "fertigstellungsdatum"
    },
    "startDate": {
      "type": "string",
      "format": "date-time",
      "description": "Gibt Tag und Uhrzeit (falls vorhanden) an, wann der Zeitraum startet."
    },
    "endDate": {
      "type": "string",
      "format": "date-time",
      "description": "Gibt Tag und Uhrzeit (falls vorhanden) an, wann der Zeitraum endet."
    },
    "balancingDate": {
      "type": "string",
      "format": "date-time",
      "description": "bilanzierungsdatum"
    },
    "beginDate": {
      "type": "string",
      "format": "date-time",
      "description": "beginndatum"
    },
    "referenceMasterDataNotificationMsb": {
      "type": "string",
      "faker": {
        "string.binary": {
          "prefix": "REF",
          "length": 6
        }
      },
      "description": "referenzStammdatenmeldungMsb"
    },
    "configuration": {
      "type": "string",
      "description": "konfiguration"
    },
    "energyConsumption": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/Consumption.schema.json"
      },
      "description": "Gibt den Verbrauch in einer Zeiteinheit an."
    }
  },
  "required": [
    "boType",
    "structureVersion"
  ]
}