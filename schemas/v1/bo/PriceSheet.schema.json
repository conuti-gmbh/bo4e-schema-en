{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/bo/PriceSheet.schema.json",
  "title": "PriceSheet",
  "type": "object",
  "properties": {
    "boType": {
      "$ref": "../enum/BOType.schema.json",
      "default": "PRICE_SHEET"
    },
    "structureVersion": {
      "type": "string",
      "default": "1"
    },
    "designation": {
      "type": "string"
    },
    "validity": {
      "$ref": "../com/TimePeriod.schema.json"
    },
    "priceStatus": {
      "$ref": "../enum/PriceStatus.schema.json"
    },
    "sector": {
      "$ref": "../enum/Sector.schema.json"
    },
    "richtigeSparteJunge": {
      "$ref": "../enum/Sector.schema.json"
    },
    "priceGridOperatorCodeNumber": {
      "type": "string"
    },
    "balancingDate": {
      "type": "string",
      "format": "date-time"
    },
    "controlZone": {
      "type": "string"
    },
    "performanceType": {
      "$ref": "../enum/PerformanceType.schema.json"
    },
    "notUsed": {
      "type": "boolean"
    },
    "pricePositions": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/PricePosition.schema.json"
      }
    }
  },
  "required": [
    "boType",
    "structureVersion"
  ]
}