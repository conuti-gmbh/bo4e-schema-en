{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/bo/CalculationFormula.schema.json",
  "title": "CalculationFormula",
  "type": "object",
  "properties": {
    "boType": {
      "$ref": "../enum/BOType.schema.json",
      "default": "CALCULATION_FORMULA"
    },
    "structureVersion": {
      "type": "string",
      "default": "1"
    },
    "beginDate": {
      "type": "string",
      "format": "date-time"
    },
    "necessity": {
      "$ref": "../enum/CalculationFormulaNecessity.schema.json"
    },
    "deliveryDirection": {
      "$ref": "../enum/EnergyDirection.schema.json"
    },
    "calculationStepId": {
      "type": "integer",
      "faker": {
        "number.int": {
          "min": 1,
          "max": 10
        }
      }
    },
    "calculationStep": {
      "$ref": "../com/CalculationStep.schema.json"
    },
    "calculationSteps": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/CalculationStep.schema.json"
      }
    },
    "purposeOfUse": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/PurposeOfUse.schema.json"
      }
    },
    "validityPeriod": {
      "$ref": "../com/TimePeriod.schema.json"
    },
    "locationId": {
      "type": "string",
      "faker": {
        "string.numeric": 11
      }
    },
    "locationType": {
      "$ref": "../enum/LocationType.schema.json"
    }
  },
  "required": [
    "boType",
    "structureVersion"
  ]
}