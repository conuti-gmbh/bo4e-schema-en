{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema/master/schemas/v1/bo/Handelsunstimmigkeit.schema.json",
  "title": "TradeDiscrepancy",
  "type": "object",
  "properties": {
    "boType": {
      "$ref": "../enum/BOType.schema.json",
      "default": "TRADE_DISCREPANCY"
    },
    "structureVersion": {
      "type": "string",
      "default": "1",
      "description": "versionStruktur"
    },
    "number": {
      "type": "string",
      "faker": {
        "string.numeric": 6
      },
      "description": "Handelsunstimmigkeitsnummer"
    },
    "typeValue": {
      "$ref": "../enum/TradeDiscrepancyType.schema.json",
      "description": "Gibt den Typ der Handelsunstimmigkeit an."
    },
    "justification": {
      "$ref": "../com/TradeDiscrepancyJustification.schema.json",
      "description": "Handelsunstimmigskeitsbegründung"
    },
    "toPay": {
      "$ref": "../com/Amount.schema.json",
      "description": "angeforderter Betrag"
    }
  },
  "required": [
    "boType",
    "structureVersion"
  ]
}