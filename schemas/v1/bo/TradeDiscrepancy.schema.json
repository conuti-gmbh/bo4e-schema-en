{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/bo/TradeDiscrepancy.schema.json",
  "title": "TradeDiscrepancy",
  "type": "object",
  "properties": {
    "boType": {
      "$ref": "../enum/BOType.schema.json",
      "default": "TRADE_DISCREPANCY"
    },
    "structureVersion": {
      "type": "string",
      "default": "1"
    },
    "number": {
      "type": "string",
      "faker": {
        "string.numeric": 6
      }
    },
    "typeValue": {
      "$ref": "../enum/TradeDiscrepancyType.schema.json"
    },
    "justification": {
      "$ref": "../com/TradeDiscrepancyJustification.schema.json"
    },
    "toPay": {
      "$ref": "../com/Amount.schema.json"
    }
  },
  "required": [
    "boType",
    "structureVersion"
  ]
}