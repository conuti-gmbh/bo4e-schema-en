{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/bo/StatusReport.schema.json",
  "title": "StatusReport",
  "type": "object",
  "properties": {
    "boType": {
      "$ref": "../enum/BOType.schema.json",
      "default": "STATUS_REPORT"
    },
    "structureVersion": {
      "type": "string",
      "default": "1"
    },
    "status": {
      "$ref": "../enum/ReportStatus.schema.json"
    },
    "auditObject": {
      "type": "string"
    },
    "reviewDate": {
      "type": "string",
      "format": "date-time"
    },
    "error": {
      "$ref": "../com/Error.schema.json"
    },
    "senderReference": {
      "type": "string"
    },
    "transactionReferenceNumber": {
      "type": "string"
    }
  },
  "required": [
    "boType",
    "structureVersion"
  ]
}