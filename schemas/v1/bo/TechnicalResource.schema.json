{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/bo/TechnicalResource.schema.json",
  "title": "TechnicalResource",
  "type": "object",
  "properties": {
    "boType": {
      "$ref": "../enum/BOType.schema.json",
      "default": "TECHNICAL_RESOURCE"
    },
    "structureVersion": {
      "type": "string",
      "default": "1"
    },
    "resourceId": {
      "type": "string",
      "faker": {
        "string.numeric": 11
      }
    },
    "sector": {
      "$ref": "../enum/Sector.schema.json"
    },
    "locationAssignment": {
      "$ref": "../enum/LocationAssignment.schema.json"
    },
    "referenceMeteringLocation": {
      "type": "string",
      "faker": {
        "string.numeric": 33
      }
    },
    "referenceMarketLocation": {
      "type": "string",
      "faker": {
        "string.numeric": 11
      }
    },
    "referenceGridLocation": {
      "type": "string",
      "faker": {
        "string.numeric": 11
      }
    },
    "referenceControllableResource": {
      "type": "string",
      "faker": {
        "string.numeric": 11
      }
    },
    "ratedPower": {
      "$ref": "../com/RatedPower.schema.json"
    },
    "storageCapacity": {
      "type": "number",
      "format": "float",
      "faker": {
        "number.float": {
          "multipleOf": 0.25,
          "min": 10,
          "max": 100
        }
      }
    },
    "consumptionType": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../enum/ConsumptionType.schema.json"
      }
    },
    "heatUsage": {
      "$ref": "../enum/HeatUsage.schema.json"
    },
    "typeElectricMobility": {
      "$ref": "../enum/TypeElectricMobility.schema.json"
    },
    "generationType": {
      "$ref": "../enum/GenerationType.schema.json"
    },
    "storageType": {
      "$ref": "../enum/StorageType.schema.json"
    },
    "enwg": {
      "type": "boolean"
    },
    "commissioningDate": {
      "$ref": "../enum/Commissioning.schema.json"
    },
    "classification": {
      "$ref": "../enum/ResourceChangeOption.schema.json"
    },
    "additionalFacility": {
      "type": "boolean"
    },
    "kind": {
      "$ref": "../enum/TechnicalResourceType.schema.json"
    },
    "dataQuality": {
      "$ref": "../enum/DataQuality.schema.json"
    },
    "validityPeriod": {
      "$ref": "../com/TimePeriod.schema.json"
    },
    "requiredProducts": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/Product.schema.json"
      }
    },
    "remoteControllability": {
      "type": "boolean"
    },
    "remunerationObligation": {
      "type": "boolean"
    }
  },
  "required": [
    "boType",
    "structureVersion"
  ]
}