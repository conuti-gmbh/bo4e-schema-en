{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema/master/schemas/v1/bo/TechnischeRessource.schema.json",
  "title": "TechnicalResource",
  "type": "object",
  "properties": {
    "boType": {
      "$ref": "../enum/BOType.schema.json",
      "default": "TECHNICAL_RESOURCE"
    },
    "structureVersion": {
      "type": "string",
      "default": "1",
      "description": "versionStruktur"
    },
    "resourceId": {
      "type": "string",
      "faker": {
        "string.numeric": 11
      },
      "description": "ressourcenId"
    },
    "sector": {
      "$ref": "../enum/Sector.schema.json"
    },
    "locationAssignment": {
      "$ref": "../enum/LocationAssignment.schema.json"
    },
    "referenceMeteringLocation": {
      "type": "string",
      "faker": {
        "string.numeric": 33
      },
      "description": "referenzMesslokation"
    },
    "referenceMarketLocation": {
      "type": "string",
      "faker": {
        "string.numeric": 11
      },
      "description": "referenzMarktlokation"
    },
    "referenceGridLocation": {
      "type": "string",
      "faker": {
        "string.numeric": 11
      },
      "description": "referenzNetzlokation"
    },
    "referenceControllableResource": {
      "type": "string",
      "faker": {
        "string.numeric": 11
      },
      "description": "referenzSteuerbareRessource"
    },
    "ratedPower": {
      "$ref": "../com/RatedPower.schema.json"
    },
    "storageCapacity": {
      "type": "number",
      "format": "float",
      "faker": {
        "number.float": {
          "multipleOf": 0.25,
          "min": 10,
          "max": 100
        }
      },
      "description": "Speicherkapazität\nBeispiel: QTY+Z42:100:KWH'"
    },
    "consumptionType": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../enum/ConsumptionType.schema.json"
      },
      "description": "Verbrauchsart der Technischen Ressource\nBeispiel: CAV+Z64'\n    Z64: Kraft/Licht\n    Z65: Wärme\n    ZE5: E-Mobilität\n    ZA8: Straßenbeleuchtung"
    },
    "heatUsage": {
      "$ref": "../enum/HeatUsage.schema.json",
      "description": "Wärmenutzung\nBeispiel: CAV+Z56'\n    Z56: Speicherheizung\n    Z57: Wärmepumpe\n    Z61: Direktheizung"
    },
    "typeElectricMobility": {
      "$ref": "../enum/TypeElectricMobility.schema.json"
    },
    "generationType": {
      "$ref": "../enum/GenerationType.schema.json",
      "description": "Art der Erzeugung der Energie. Details Erzeugungsart\nBeispiel: CAV+ZF5'\nErzeugungsart:\n    ZF5: Solar\n    ZF6: Wind\n    ZG0: Gas\n    ZG1: Wasser\n    ZG5: Sonstige Erzeugungsart"
    },
    "storageType": {
      "$ref": "../enum/StorageType.schema.json",
      "description": "Art der speicher. Details Speicherart\nBeispiel: CAV+ZF7'\nSpeicherart:\n    ZF7: Wasserstoffspeicher\n    ZF8: Pumpspeicher\n    ZF9: Batteriespeicher\n    ZG6: Sonstige Speicherart"
    },
    "enwg": {
      "type": "boolean",
      "description": "enwg"
    },
    "commissioningDate": {
      "$ref": "../enum/Commissioning.schema.json"
    },
    "classification": {
      "$ref": "../enum/ResourceChangeOption.schema.json"
    },
    "additionalFacility": {
      "type": "boolean",
      "description": "weitereEinrichtung"
    },
    "kind": {
      "$ref": "../enum/TechnicalResourceType.schema.json"
    },
    "dataQuality": {
      "$ref": "../enum/DataQuality.schema.json"
    },
    "validityPeriod": {
      "$ref": "../com/TimePeriod.schema.json"
    },
    "requiredProducts": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/Product.schema.json"
      },
      "description": "erforderlicheProdukte"
    }
  },
  "required": [
    "boType",
    "structureVersion"
  ]
}