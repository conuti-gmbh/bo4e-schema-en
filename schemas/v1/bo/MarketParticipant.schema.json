{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/bo/MarketParticipant.schema.json",
  "title": "MarketParticipant",
  "type": "object",
  "properties": {
    "boType": {
      "$ref": "../enum/BOType.schema.json",
      "default": "MARKET_PARTICIPANT"
    },
    "structureVersion": {
      "type": "string",
      "default": "1"
    },
    "businessPartnerRole": {
      "$ref": "../enum/BusinessPartnerRole.schema.json"
    },
    "salutation": {
      "type": "string",
      "faker": "person.prefix"
    },
    "name1": {
      "type": "string",
      "faker": "person.lastName"
    },
    "name2": {
      "type": "string",
      "faker": "person.firstName"
    },
    "name3": {
      "type": "string"
    },
    "name4": {
      "type": "string"
    },
    "partnerAddress": {
      "$ref": "../com/Address.schema.json"
    },
    "commercialClassification": {
      "type": "boolean"
    },
    "externalCustomerNumberSupplier": {
      "type": "string"
    },
    "marketRole": {
      "$ref": "../enum/MarketRole.schema.json"
    },
    "roleCodeNumber": {
      "type": "string",
      "faker": {
        "string.numeric": 9
      }
    },
    "roleCodeType": {
      "$ref": "../enum/RoleCodeType.schema.json"
    },
    "vatId": {
      "type": "string",
      "faker": {
        "string.binary": {
          "prefix": "DE",
          "length": 9
        }
      }
    },
    "taxNumber": {
      "type": "string",
      "faker": {
        "string.numeric": 9
      }
    },
    "contactPerson": {
      "$ref": "../bo/ContactPerson.schema.json"
    },
    "makoAddress": {
      "type": "string"
    },
    "certificateDownloadLink": {
      "type": "string",
      "faker": "internet.url"
    },
    "courtOfRegistration": {
      "type": "string",
      "faker": "location.city"
    },
    "commercialRegisterNumber": {
      "type": "string",
      "faker": {
        "string.numeric": 6
      }
    },
    "website": {
      "type": "string",
      "faker": "internet.url"
    },
    "faxNumber": {
      "type": "string",
      "faker": "phone.number"
    },
    "communicationRole": {
      "$ref": "../enum/CommunicationRole.schema.json"
    },
    "subContracted": {
      "type": "boolean"
    },
    "communicationParameters": {
      "$ref": "../com/CommunicationParameters.schema.json"
    },
    "meteringPointOperatorAttribute": {
      "$ref": "../enum/MSBAttribute.schema.json"
    },
    "bankAccount": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/BankAccount.schema.json"
      }
    },
    "reachability": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/Reachability.schema.json"
      }
    },
    "ipAddress": {
      "type": "string",
      "faker": "internet.ip"
    },
    "ipRange": {
      "$ref": "../com/IpRange.schema.json"
    },
    "assignmentFrom": {
      "type": "string",
      "format": "date-time"
    },
    "assignmentTo": {
      "type": "string",
      "format": "date-time"
    },
    "balancingGroup": {
      "type": "string"
    },
    "balancingGroupPurpose": {
      "$ref": "../enum/BalancingGroupPurpose.schema.json"
    }
  },
  "required": [
    "boType",
    "structureVersion"
  ]
}