{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/bo/BalancingGroup.schema.json",
  "title": "BalancingGroup",
  "type": "object",
  "properties": {
    "boType": {
      "$ref": "../enum/BOType.schema.json",
      "default": "BALANCING_GROUP"
    },
    "structureVersion": {
      "type": "string",
      "default": "1"
    },
    "designation": {
      "type": "string"
    },
    "priority": {
      "type": "integer",
      "faker": {
        "number.int": {
          "min": 1,
          "max": 10
        }
      }
    }
  }
}