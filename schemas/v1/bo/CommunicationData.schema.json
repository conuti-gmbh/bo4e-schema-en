{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema/master/schemas/v1/bo/Kommunikationsdaten.schema.json",
  "title": "CommunicationData",
  "type": "object",
  "properties": {
    "boType": {
      "$ref": "../enum/BOType.schema.json",
      "default": "COMMUNICATION_DATA"
    },
    "structureVersion": {
      "type": "string",
      "default": "1",
      "description": "versionStruktur"
    },
    "validity": {
      "type": "string",
      "format": "date-time",
      "description": "gueltigkeit"
    },
    "communicationDataSheetInactive": {
      "type": "boolean",
      "description": "kommunikationsDatenBlattInaktiv"
    },
    "marketParticipant": {
      "$ref": "../bo/MarketParticipant.schema.json"
    },
    "communicationDetails": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../bo/MarketParticipant.schema.json"
      },
      "description": "kommunikationsangaben"
    }
  },
  "required": [
    "boType",
    "structureVersion"
  ]
}