{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/bo/CommunicationData.schema.json",
  "title": "CommunicationData",
  "type": "object",
  "properties": {
    "boType": {
      "$ref": "../enum/BOType.schema.json",
      "default": "COMMUNICATION_DATA"
    },
    "structureVersion": {
      "type": "string",
      "default": "1"
    },
    "validity": {
      "type": "string",
      "format": "date-time"
    },
    "communicationDataSheetInactive": {
      "type": "boolean"
    },
    "marketParticipant": {
      "$ref": "../bo/MarketParticipant.schema.json"
    },
    "communicationDetails": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../bo/MarketParticipant.schema.json"
      }
    }
  },
  "required": [
    "boType",
    "structureVersion"
  ]
}