{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/bo/Offer.schema.json",
  "title": "Offer",
  "type": "object",
  "properties": {
    "boType": {
      "$ref": "../enum/BOType.schema.json",
      "default": "OFFER"
    },
    "structureVersion": {
      "type": "string",
      "default": "1"
    },
    "offerNumber": {
      "type": "string",
      "faker": {
        "string.numeric": 3
      }
    },
    "requestReference": {
      "type": "string",
      "faker": {
        "string.binary": {
          "prefix": "REF",
          "length": 6
        }
      }
    },
    "offerDate": {
      "type": "string",
      "format": "date-time"
    },
    "sector": {
      "$ref": "../enum/Sector.schema.json"
    },
    "bindingPeriod": {
      "type": "string",
      "format": "date-time"
    },
    "offerGiver": {
      "$ref": "../bo/BusinessPartner.schema.json"
    },
    "offerRecipient": {
      "$ref": "../bo/BusinessPartner.schema.json"
    },
    "signatoryOfferRecipient": {
      "$ref": "../bo/ContactPerson.schema.json"
    },
    "signatoryOfferGiver": {
      "$ref": "../bo/ContactPerson.schema.json"
    },
    "setupTransmissionPeriod": {
      "$ref": "../com/TimePeriod.schema.json"
    },
    "offerBindingPeriod": {
      "$ref": "../com/TimePeriod.schema.json"
    },
    "variants": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/OfferVariant.schema.json"
      }
    },
    "positionData": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/OfferPosition.schema.json"
      }
    }
  },
  "required": [
    "boType",
    "structureVersion"
  ]
}