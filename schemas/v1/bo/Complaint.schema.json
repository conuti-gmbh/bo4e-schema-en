{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema/master/schemas/v1/bo/Reklamation.schema.json",
  "title": "Complaint",
  "type": "object",
  "properties": {
    "boType": {
      "$ref": "../enum/BOType.schema.json",
      "default": "COMPLAINT"
    },
    "structureVersion": {
      "type": "string",
      "default": "1",
      "description": "versionStruktur"
    },
    "locationId": {
      "type": "string",
      "faker": {
        "string.numeric": 11
      },
      "description": "Für welche Markt- oder Messlokation gilt diese Reklamation."
    },
    "locationType": {
      "$ref": "../enum/LocationType.schema.json",
      "description": "Gibt an, ob es sich um eine Markt- oder Messlokation handelt."
    },
    "obisNumber": {
      "type": "string",
      "description": "OBIS-Kennzahl"
    },
    "measurementValueRequestPeriod": {
      "$ref": "../com/TimePeriod.schema.json"
    },
    "complaintReason": {
      "$ref": "../enum/ComplaintReason.schema.json",
      "description": "Hier wird für die Reklamation von Werten der Reklamationsgrund angegeben."
    },
    "complaintReasonNote": {
      "$ref": "../com/ComplaintReasonNote.schema.json",
      "description": "Freitext für eine weitere Beschreibung des Reklamationsgrunds"
    },
    "configuration": {
      "type": "string",
      "description": "konfiguration"
    }
  },
  "required": [
    "boType",
    "structureVersion"
  ]
}