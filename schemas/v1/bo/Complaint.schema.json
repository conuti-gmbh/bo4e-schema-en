{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/bo/Complaint.schema.json",
  "title": "Complaint",
  "type": "object",
  "properties": {
    "boType": {
      "$ref": "../enum/BOType.schema.json",
      "default": "COMPLAINT"
    },
    "structureVersion": {
      "type": "string",
      "default": "1"
    },
    "locationId": {
      "type": "string",
      "faker": {
        "string.numeric": 11
      }
    },
    "locationType": {
      "$ref": "../enum/LocationType.schema.json"
    },
    "obisNumber": {
      "type": "string"
    },
    "measurementValueRequestPeriod": {
      "$ref": "../com/TimePeriod.schema.json"
    },
    "complaintReason": {
      "$ref": "../enum/ComplaintReason.schema.json"
    },
    "complaintReasonNote": {
      "$ref": "../com/ComplaintReasonNote.schema.json"
    },
    "configuration": {
      "type": "string"
    }
  },
  "required": [
    "boType",
    "structureVersion"
  ]
}