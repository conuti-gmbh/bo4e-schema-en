{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/bo/Balancing.schema.json",
  "title": "Balancing",
  "type": "object",
  "properties": {
    "boType": {
      "$ref": "../enum/BOType.schema.json",
      "default": "BALANCING"
    },
    "structureVersion": {
      "type": "string",
      "default": "1"
    },
    "marketLocationId": {
      "type": "string",
      "faker": {
        "string.numeric": 11
      }
    },
    "aggregationResponsibility": {
      "$ref": "../enum/AggregationResponsibility.schema.json"
    },
    "timeSeriesType": {
      "$ref": "../enum/TimeSeriesType.schema.json"
    },
    "forecastBasis": {
      "$ref": "../enum/ForecastBasis.schema.json"
    },
    "balancingStart": {
      "type": "string",
      "format": "date-time"
    },
    "balancingEnd": {
      "type": "string",
      "format": "date-time"
    },
    "balancingGroup": {
      "type": "string"
    },
    "balancingGroups": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../bo/BalancingGroup.schema.json"
      }
    },
    "caseGroupAssignment": {
      "$ref": "../enum/CaseGroupAssignment.schema.json"
    },
    "temperatureWork": {
      "$ref": "../com/Quantity.schema.json"
    },
    "annualConsumptionForecast": {
      "$ref": "../com/Quantity.schema.json"
    },
    "customerValue": {
      "$ref": "../com/Quantity.schema.json"
    },
    "consumptionAllocation": {
      "$ref": "../com/Quantity.schema.json"
    },
    "forecastBasisChoiceRight": {
      "$ref": "../enum/ForecastBasisChoiceRight.schema.json"
    },
    "forecastBasisChoiceRightReason": {
      "$ref": "../enum/ForecastBasisChoiceRight.schema.json"
    },
    "settlementModel": {
      "$ref": "../enum/SettlementModel.schema.json"
    },
    "priorYearConsumption": {
      "$ref": "../com/Quantity.schema.json"
    },
    "dataQuality": {
      "$ref": "../enum/DataQuality.schema.json"
    },
    "validityPeriod": {
      "$ref": "../com/TimePeriod.schema.json"
    },
    "loadProfiles": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/LoadProfile.schema.json"
      }
    },
    "loadProfilesBalancingParty": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/LoadProfile.schema.json"
      }
    },
    "forecastBasisDetails": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../enum/ProfileSubtype.schema.json"
      }
    }
  },
  "required": [
    "boType",
    "structureVersion"
  ]
}