{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/bo/LocationBundle.schema.json",
  "title": "LocationBundle",
  "type": "object",
  "properties": {
    "boType": {
      "$ref": "../enum/BOType.schema.json",
      "default": "LOCATION_BUNDLE"
    },
    "structureVersion": {
      "type": "string",
      "default": "1"
    },
    "locationBundleStructureId": {
      "type": "string",
      "faker": {
        "string.numeric": 11
      }
    },
    "locationBundleNumber": {
      "type": "integer"
    },
    "standardizedLocationBundleStructure": {
      "type": "boolean"
    },
    "dataQuality": {
      "$ref": "../enum/DataQuality.schema.json"
    },
    "validityPeriod": {
      "$ref": "../com/TimePeriod.schema.json"
    },
    "assignmentObjectCode": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/AssignmentObjectCode.schema.json"
      }
    }
  },
  "required": [
    "boType",
    "structureVersion"
  ]
}