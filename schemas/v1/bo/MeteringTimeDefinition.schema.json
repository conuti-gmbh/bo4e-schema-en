{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema/master/schemas/v1/bo/Zaehlzeitdefinition.schema.json",
  "title": "MeteringTimeDefinition",
  "type": "object",
  "properties": {
    "boType": {
      "$ref": "../enum/BOType.schema.json",
      "default": "METERING_TIME_DEFINITION"
    },
    "structureVersion": {
      "type": "string",
      "default": "1",
      "description": "versionStruktur"
    },
    "beginDate": {
      "type": "string",
      "format": "date-time",
      "description": "Der inklusive Zeitpunkt ab dem die Zaehlzeitdefinitionen ausgerollt sind"
    },
    "closingDate": {
      "type": "string",
      "format": "date-time",
      "description": "Der exklusive Zeitpunkt bis zu dem die Zaehlzeitdefinitionen ausgerollt sind"
    },
    "version": {
      "type": "string",
      "format": "date-time",
      "description": "Version der Zählzeitdefinition als Datum"
    },
    "necessity": {
      "$ref": "../enum/DefinitionsNecessity.schema.json",
      "description": "Beschreibt ob eine Zaehlzeitdefinitionen notwendig ist"
    },
    "versionSpecification": {
      "type": "string",
      "faker": {
        "string.binary": {
          "prefix": "VERSION_",
          "length": 6
        }
      },
      "description": "versionsangabe"
    },
    "code": {
      "type": "string",
      "faker": {
        "string.binary": {
          "prefix": "CODE_",
          "length": 6
        }
      },
      "description": "Zählzeitdefinition"
    },
    "meteringTimes": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/MeteringTime.schema.json"
      },
      "description": "Liste der Zählzeiten [1 - 99999]"
    },
    "meteringTimeRegister": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/MeteringTimeRegister.schema.json"
      },
      "description": "Liste der Zählzeitregister"
    }
  },
  "required": [
    "boType",
    "structureVersion"
  ]
}