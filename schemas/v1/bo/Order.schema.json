{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/bo/Order.schema.json",
  "title": "Order",
  "type": "object",
  "properties": {
    "boType": {
      "$ref": "../enum/BOType.schema.json",
      "default": "ORDER"
    },
    "structureVersion": {
      "type": "string",
      "default": "1"
    },
    "executionDate": {
      "type": "string",
      "format": "date-time"
    },
    "completionDate": {
      "type": "string",
      "format": "date-time"
    },
    "startDate": {
      "type": "string",
      "format": "date-time"
    },
    "endDate": {
      "type": "string",
      "format": "date-time"
    },
    "sector": {
      "$ref": "../enum/Sector.schema.json"
    },
    "deliveryAddress": {
      "$ref": "../com/Address.schema.json"
    },
    "marketLocationId": {
      "type": "string",
      "faker": {
        "string.numeric": 11
      }
    },
    "minimumPrice": {
      "$ref": "../com/Price.schema.json"
    },
    "maximumPrice": {
      "$ref": "../com/Price.schema.json"
    },
    "energyDirection": {
      "$ref": "../enum/EnergyDirection.schema.json"
    },
    "calculationPrice": {
      "type": "number",
      "format": "float",
      "faker": {
        "number.float": {
          "multipleOf": 0.25,
          "min": 1,
          "max": 10
        }
      }
    },
    "totalSum": {
      "type": "number",
      "format": "float",
      "faker": {
        "number.float": {
          "multipleOf": 0.25,
          "min": 10,
          "max": 20
        }
      }
    },
    "postponedDeregistrationDate": {
      "type": "string",
      "format": "date-time"
    },
    "resolutionTimestamp": {
      "type": "string",
      "format": "date-time"
    },
    "deliveryAddressOldDevices": {
      "$ref": "../bo/BusinessPartner.schema.json"
    },
    "definitionType": {
      "$ref": "../enum/DefinitionType.schema.json"
    },
    "positionData": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/OrderPosition.schema.json"
      }
    },
    "remarks": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string",
        "faker": {
          "lorem.sentence": 5
        }
      }
    }
  },
  "required": [
    "boType",
    "structureVersion"
  ]
}