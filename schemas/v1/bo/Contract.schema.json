{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/bo/Contract.schema.json",
  "title": "Contract",
  "type": "object",
  "properties": {
    "boType": {
      "$ref": "../enum/BOType.schema.json",
      "default": "CONTRACT"
    },
    "structureVersion": {
      "type": "string",
      "default": "1"
    },
    "sector": {
      "$ref": "../enum/Sector.schema.json"
    },
    "contractType": {
      "type": "string"
    },
    "contractNumber": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "locationId": {
      "type": "string",
      "faker": {
        "string.numeric": 11
      }
    },
    "locationType": {
      "$ref": "../enum/LocationType.schema.json"
    },
    "contractStatus": {
      "$ref": "../enum/ContractStatus.schema.json"
    },
    "contractStart": {
      "type": "string",
      "format": "date-time"
    },
    "contractEnd": {
      "type": "string",
      "format": "date-time"
    },
    "municipalDiscount": {
      "type": "integer",
      "faker": {
        "number.int": {
          "min": 10,
          "max": 30
        }
      }
    },
    "contractConditions": {
      "$ref": "../com/ContractConditions.schema.json"
    },
    "correspondencePartner": {
      "$ref": "../bo/BusinessPartner.schema.json"
    },
    "billingViaNna": {
      "type": "boolean"
    },
    "dataQuality": {
      "$ref": "../enum/DataQuality.schema.json"
    },
    "validityPeriod": {
      "$ref": "../com/TimePeriod.schema.json"
    },
    "contractPartner1": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../bo/BusinessPartner.schema.json"
      }
    },
    "contractPartner2": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../bo/BusinessPartner.schema.json"
      }
    },
    "enfg": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/EnFG.schema.json"
      }
    }
  },
  "required": [
    "boType",
    "structureVersion"
  ]
}