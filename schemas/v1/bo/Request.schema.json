{
  "$schema": "../object.meta.schema.json",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/bo/Request.schema.json",
  "title": "Request",
  "type": "object",
  "properties": {
    "boType": {
      "$ref": "../enum/BOType.schema.json",
      "default": "REQUEST"
    },
    "structureVersion": {
      "type": "string",
      "default": "1"
    },
    "locationType": {
      "$ref": "../enum/LocationType.schema.json"
    },
    "locationId": {
      "type": "string",
      "faker": {
        "string.numeric": 11
      }
    },
    "requestType": {
      "$ref": "../enum/RequestType.schema.json"
    },
    "subscription": {
      "$ref": "../enum/Subscription.schema.json",
      "description": "Start or end of subscription"
    },
    "requestReference": {
      "type": "string",
      "faker": {
        "string.binary": {
          "prefix": "REF",
          "length": 6
        }
      }
    },
    "generalInformation": {
      "type": "string"
    },
    "requestCategory": {
      "$ref": "../enum/RequestCategory.schema.json"
    },
    "energyDirection": {
      "$ref": "../enum/EnergyDirection.schema.json"
    },
    "validityDuration": {
      "type": "string",
      "faker": {
        "string.numeric": 6
      }
    },
    "validFrom": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "boType",
    "structureVersion"
  ]
}