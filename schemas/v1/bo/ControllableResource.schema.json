{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema/master/schemas/v1/bo/SteuerbareRessource.schema.json",
  "title": "ControllableResource",
  "type": "object",
  "properties": {
    "boType": {
      "$ref": "../enum/BOType.schema.json",
      "default": "CONTROLLABLE_RESOURCE"
    },
    "structureVersion": {
      "type": "string",
      "default": "1",
      "description": "versionStruktur"
    },
    "resourceId": {
      "type": "string",
      "faker": {
        "string.numeric": 11
      },
      "description": "ressourcenId"
    },
    "sector": {
      "$ref": "../enum/Sector.schema.json"
    },
    "locationAssignment": {
      "$ref": "../enum/LocationAssignment.schema.json"
    },
    "configurationProduct": {
      "type": "string",
      "description": "konfigurationsprodukt"
    },
    "controlChannel": {
      "$ref": "../enum/ControlChannel.schema.json"
    },
    "productDataRelevantRole": {
      "$ref": "../enum/MarketRole.schema.json"
    },
    "orderingMarketPartner": {
      "$ref": "../bo/MarketParticipant.schema.json"
    },
    "assignedDefinition": {
      "$ref": "../com/AssignedDefinition.schema.json"
    },
    "marketRoles": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../bo/MarketParticipant.schema.json"
      },
      "description": "marktrollen"
    },
    "dataQuality": {
      "$ref": "../enum/DataQuality.schema.json"
    },
    "validityPeriod": {
      "$ref": "../com/TimePeriod.schema.json"
    },
    "requiredProducts": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/Product.schema.json"
      },
      "description": "erforderlicheProdukte"
    }
  },
  "required": [
    "boType",
    "structureVersion"
  ]
}