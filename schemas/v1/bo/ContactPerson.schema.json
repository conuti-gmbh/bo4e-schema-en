{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema-en/main/schemas/v1/bo/ContactPerson.schema.json",
  "title": "ContactPerson",
  "type": "object",
  "properties": {
    "boType": {
      "$ref": "../enum/BOType.schema.json",
      "default": "CONTACT_PERSON"
    },
    "structureVersion": {
      "type": "string",
      "default": "1"
    },
    "lastName": {
      "type": "string",
      "faker": "person.lastName"
    },
    "eMailAddress": {
      "type": "string",
      "faker": "internet.email"
    },
    "phoneNumbers": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/PhoneNumber.schema.json"
      }
    }
  },
  "required": [
    "boType",
    "structureVersion"
  ]
}