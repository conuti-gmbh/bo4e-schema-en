{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/conuti-gmbh/bo4e-schema/master/schemas/v1/bo/Ansprechpartner.schema.json",
  "title": "ContactPerson",
  "type": "object",
  "properties": {
    "boType": {
      "$ref": "../enum/BOType.schema.json",
      "default": "CONTACT_PERSON"
    },
    "structureVersion": {
      "type": "string",
      "default": "1",
      "description": "versionStruktur"
    },
    "lastName": {
      "type": "string",
      "faker": "person.lastName",
      "description": "Nachname (Familienname) des Ansprechpartners"
    },
    "eMailAddress": {
      "type": "string",
      "faker": "internet.email",
      "description": "E-Mail Adresse"
    },
    "phoneNumbers": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "../com/PhoneNumber.schema.json"
      },
      "description": "Liste der Telefonnummern, unter denen der Ansprechpartner erreichbar ist."
    }
  },
  "required": [
    "boType",
    "structureVersion"
  ]
}